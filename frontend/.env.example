# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (used only by one-off scripts, e.g. db setup / seeding)
DATABASE_URL=postgresql://postgres.your-project:password@your-pooler-host:6543/postgres

# Admin login (single admin account, change anytime)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Session signing secret (any long random string)
SESSION_SECRET=generate-a-random-64-char-hex-string
